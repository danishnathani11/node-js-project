<%- include('../partials/header', { title: 'Edit Book' }) %>

<div class="page-header">
  <div class="page-header-content">
    <h1 class="page-title">Edit Book</h1>
    <p class="page-subtitle">Update the details for "<%= book.title %>"</p>
  </div>
  <a href="/books/<%= book._id %>" class="btn btn-ghost">← Back to Book</a>
</div>

<% if (errors && errors.length > 0) { %>
  <div class="alert alert-error">
    <strong>⚠️ Please fix the following:</strong>
    <ul>
      <% errors.forEach(err => { %><li><%= err %></li><% }) %>
    </ul>
  </div>
<% } %>

<div class="form-container">
  <form action="/books/<%= book._id %>?_method=PUT" method="POST" enctype="multipart/form-data" class="book-form">

    <div class="form-row">
      <div class="form-group">
        <label for="title">Book Title <span class="required">*</span></label>
        <input
          type="text" id="title" name="title"
          value="<%= typeof formData !== 'undefined' ? formData.title : book.title %>"
          required class="form-input"
        />
      </div>
      <div class="form-group">
        <label for="author">Author Name <span class="required">*</span></label>
        <input
          type="text" id="author" name="author"
          value="<%= typeof formData !== 'undefined' ? formData.author : book.author %>"
          required class="form-input"
        />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="category">Category <span class="required">*</span></label>
        <select id="category" name="category" required class="form-select">
          <% categories.forEach(cat => { %>
            <option value="<%= cat %>" <%= book.category === cat ? 'selected' : '' %>><%= cat %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="price">Price (₹) <span class="required">*</span></label>
        <input
          type="number" id="price" name="price"
          value="<%= typeof formData !== 'undefined' ? formData.price : book.price %>"
          min="0" step="0.01" required class="form-input"
        />
      </div>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="quantity">Quantity <span class="required">*</span></label>
        <input
          type="number" id="quantity" name="quantity"
          value="<%= typeof formData !== 'undefined' ? formData.quantity : book.quantity %>"
          min="0" required class="form-input"
        />
      </div>
      <div class="form-group">
        <label>Book Cover Image</label>
        <% if (book.image) { %>
          <div class="current-image">
            <img src="/uploads/<%= book.image %>" alt="Current cover" class="current-cover-thumb" />
            <span class="current-img-label">Current image</span>
          </div>
        <% } %>
        <div class="file-upload-wrapper" style="margin-top: 0.5rem;">
          <input type="file" id="image" name="image" accept="image/*" class="file-input" />
          <label for="image" class="file-upload-label">
            <span class="file-icon">🔄</span>
            <span class="file-text"><%= book.image ? 'Replace Image' : 'Upload Image' %></span>
          </label>
          <div class="image-preview-wrap" id="imagePreview" style="display:none;">
            <img id="previewImg" src="" alt="New Preview" />
            <button type="button" onclick="clearImage()" class="clear-img-btn">✕</button>
          </div>
        </div>
      </div>
    </div>

    <div class="form-group full-width">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4" class="form-textarea"><%= book.description || '' %></textarea>
    </div>

    <div class="form-actions">
      <form action="/books/<%= book._id %>?_method=DELETE" method="POST" style="display:inline;">
        <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this book permanently?')">🗑️ Delete Book</button>
      </form>
      <div>
        <a href="/books/<%= book._id %>" class="btn btn-ghost">Cancel</a>
        <button type="submit" class="btn btn-primary">💾 Save Changes</button>
      </div>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>
